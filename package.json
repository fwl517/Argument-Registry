{
  "name": "political-society-db",
  "version": "2.0.0",
  "description": "Political Society Argument & Source Database Engine — Node.js + Express + PostgreSQL",
  "type": "commonjs",
  "main": "server/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
