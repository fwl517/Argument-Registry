    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "unzipper": "^0.12.3"
  },
