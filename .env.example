# ================================================================
# Political Society Argument & Source Database Engine
# Environment configuration — copy to `.env` and fill in.
# Never commit the real `.env` file.
# ================================================================

# PostgreSQL connection string.
DATABASE_URL=postgres://psdb_app:CHANGE_ME@localhost:5432/political_society

# Absolute path to the directory where uploaded files are stored.
# MUST be OUTSIDE the public web root.
FILE_STORE_PATH=/var/lib/political-society/uploads

# HTTP port the Express server listens on.
PORT=3000

# Set to "production" in deployment. Controls Secure cookie flag and
# whether verbose errors are suppressed.
NODE_ENV=development

# When NODE_ENV is not "production" you may set this to "false" to allow
# cookies over plain HTTP during local development (no TLS).
# In production this is ignored and Secure is always forced on.
COOKIE_SECURE=false
